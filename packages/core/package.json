{
  "name": "vue-onigiri",
  "version": "0.4.0",
  "description": "Serialize and deserialize Vue component trees (VNodes) for Vue Server Components and cross-application component sharing",
  "license": "MIT",
  "repository": "vue-onigiri",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime/*": {
      "types": "./dist/runtime/*.d.ts",
      "import": "./dist/runtime/*.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "unbuild",
    "lint": "eslint .",
    "lint:fix": "automd && eslint . --fix",
    "prepack": "pnpm build",
    "test": "pnpm lint && pnpm test:types && vitest run --coverage",
    "test:types": "vue-tsc"
  },
  "dependencies": {
    "@babel/parser": "^7.29.3",
    "@vue/compiler-dom": "^3.5.33",
    "@vue/compiler-sfc": "^3.5.33",
    "@vue/shared": "^3.5.33",
    "knitwork": "^1.3.0",
    "magic-string": "^0.30.21"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "@vue/server-renderer": "^3.5.33",
    "@vue/test-utils": "^2.4.10",
    "automd": "^0.4.3",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vite": "catalog:",
    "vite-plugin-mcp": "^0.3.2",
    "vitest": "catalog:",
    "vue": "^3.5.33",
    "vue-tsc": "^3.2.8"
  },
  "peerDependencies": {
    "@vue/server-renderer": "^3.5.0",
    "vite": ">=6.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@vue/server-renderer": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  }
}
