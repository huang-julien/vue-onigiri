{
  "name": "vue-onigiri-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "vue-onigiri monorepo root",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter vue-onigiri build",
    "dev": "pnpm --filter playground dev",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "test": "pnpm --filter vue-onigiri test",
    "test:types": "pnpm -r test:types",
    "release": "pnpm test && changelogen --release --cwd packages/vue-onigiri && cd packages/vue-onigiri && npm publish && cd ../.. && git push --follow-tags"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "changelogen": "^0.6.2",
    "eslint": "^9.39.4",
    "eslint-config-unjs": "^0.6.2",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.7.0"
}
